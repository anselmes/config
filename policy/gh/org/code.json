{
  "name": "code",
  "target": "branch",
  "source_type": "Organization",
  "source": "organization_name",
  "enforcement": "active",
  "conditions": {
    "repository_name": {
      "exclude": [],
      "include": ["~ALL"]
    },
    "ref_name": {
      "exclude": [],
      "include": ["~DEFAULT_BRANCH"]
    }
  },
  "rules": [
    {
      "type": "workflows",
      "parameters": {
        "do_not_enforce_on_create": true,
        "workflows": [
          {
            "repository_id": "repository_id",
            "path": ".github/workflows/review.yml",
            "ref": "refs/heads/main"
          }
        ]
      }
    }
  ],
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    },
    {
      "actor_id": 1,
      "actor_type": "OrganizationAdmin",
      "bypass_mode": "always"
    }
  ]
}
